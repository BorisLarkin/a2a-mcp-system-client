# .env (в корне проекта)
# PostgreSQL
POSTGRES_USER=dispatcher_user
POSTGRES_PASSWORD=strong_local_password_123
POSTGRES_DB=dispatcher_db
DB_PASSWORD=strong_local_password_123

# Redis
REDIS_PASSWORD=redis_password_456

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Orchestrator (компьютер А)
ORCHESTRATOR_URL=http://192.168.1.100:8081  # ЗАМЕНИТЕ НА ВАШ IP!
ORCHESTRATOR_API_KEY=sk_live_abc123xyz789

# Telegram
TELEGRAM_WEBHOOK_SECRET=telegram_webhook_secret_123
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/v1/webhook/telegram  # Для продакшена
TELEGRAM_API_KEY=internal_api_key_for_telegram
TELEGRAM_BOT_TOKEN=121
CLOUD_API_KEY=0
API_KEY=12312
# TELEGRAM
BOT_TOKEN=1212
BOT_USERNAME=a2a_mcp_company_support_bot

# LOCAL-PROXY API
API_URL=http://localhost:8080
API_ENDPOINT=/api/v1/tickets
API_TIMEOUT=10
LOCAL_API_URL=http://local-proxy:8080

# НАСТРОЙКИ БОТА
RATE_LIMIT_PER_USER=5  # сообщений в минуту
MAX_MESSAGE_LENGTH=4000
LOG_LEVEL=INFO

# ОФЛАЙН РЕЖИМ
OFFLINE_RESPONSE="Спасибо за обращение! Мы получили ваше сообщение и ответим при первой возможности."
MAINTENANCE_MODE=false

# React
REACT_APP_API_URL=http://localhost:8080
REACT_APP_WS_URL=ws://localhost:8080

# Локальные настройки
DISPATCHER_NAME="Тестовая диспетчерская"
DEFAULT_CHANNEL=telegram
DISPATCHER_ID=1
AUTO_RESPONSE_ENABLED=true
WORK_HOURS_START=09:00
WORK_HOURS_END=18:00