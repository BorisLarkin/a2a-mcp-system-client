version: '3.8'

services:
  postgres:
    extends:
      file: ./local-db/docker-compose.yml
      service: postgres
    
  local-proxy:
    extends:
      file: ./local-proxy/docker-compose.yml
      service: local-proxy
    
  telegram-bot:
    extends:
      file: ./telegram-bot/docker-compose.yml
      service: telegram-bot
    
  web-dashboard:
    build: ./web-dashboard
    ports:
      - "80:80"
    volumes:
      - ./web-dashboard/frontend:/usr/share/nginx/html
    depends_on:
      - local-proxy
    networks:
      - mcp-client-network

networks:
  mcp-client-network:
    driver: bridge